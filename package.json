{
  "name": "iris",
  "version": "0.0.0",
  "private": true,
  "description": "Iris React Native JavaScript runtime experiments.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bench:android-release": "bun run tools/bench/run-android-release-benchmark.ts",
    "bench:android-release:repeat": "bun run tools/bench/run-android-release-benchmark.ts --runs=3 --summary-output=artifacts/bench/hermes-release-baseline-summary.json",
    "bench:android-engine-compare": "bun run tools/bench/run-android-engine-comparison.ts",
    "bench:android-engine-compare:check": "bun run tools/bench/run-android-engine-comparison.ts --check-inputs-only",
    "bench:android-hermes-iris-bridge": "bun run tools/bench/run-android-release-benchmark.ts --app-id=com.iris.bench.hermesbridge --apk=apps/rn-bench/android/app/build/outputs/apk/hermesBridge/release/app-hermesBridge-release.apk --runs=3 --require-case=js-compute --require-case=json-round-trip --require-case=object-traversal --require-case=typed-array-copy --require-case=turbomodule-number-round-trip --require-case=turbomodule-string-round-trip --require-case=iris-module-native-compute --require-case=iris-jsi-number-round-trip --require-case=iris-jsi-string-round-trip --require-case=iris-jsi-native-compute --require-case=iris-jsi-facade-number-round-trip --require-case=iris-jsi-facade-string-round-trip --require-case=iris-jsi-facade-native-compute --require-case=iris-jsi-columnar-object-traversal --require-case=iris-jsi-native-buffer-read --log-output=artifacts/bench/rn-release-hermes-iris-bridge.log --report-output=artifacts/bench/hermes-iris-bridge-baseline.json --summary-output=artifacts/bench/hermes-iris-bridge-baseline-summary.json --session=rnbench-android-hermes-iris-bridge-release",
    "bench:android-iris-bootstrap": "bun run tools/bench/run-android-release-benchmark.ts --app-id=com.iris.bench.iris --apk=apps/rn-bench/android/app/build/outputs/apk/iris/release/app-iris-release.apk --allow-non-hermes --native-bootstrap-artifact --wait-ms=10000 --runs=3 --log-output=artifacts/bench/rn-release-iris-bootstrap.log --report-output=artifacts/bench/iris-bootstrap-baseline.json --summary-output=artifacts/bench/iris-bootstrap-baseline-summary.json",
    "bench:android-iris-qjs": "bun run tools/bench/run-android-release-benchmark.ts --app-id=com.iris.bench.iris --apk=apps/rn-bench/android/app/build/outputs/apk/iris/release/app-iris-release.apk --allow-non-hermes --native-bootstrap-artifact --wait-ms=60000 --runs=3 --suite-id=iris-qjs-backend-microbenchmark --require-case=js-compute --require-case=json-round-trip --require-case=object-traversal --require-case=typed-array-copy --log-output=artifacts/bench/rn-release-iris-qjs.log --report-output=artifacts/bench/iris-qjs-android-baseline.json --summary-output=artifacts/bench/iris-qjs-android-baseline-summary.json",
    "bench:android-local-performance": "bun run bench:android-release:repeat && bun run bench:android-iris-bootstrap && bun run bench:android-local-performance-report",
    "bench:android-local-performance-report": "bun run tools/bench/write-android-local-performance-report.ts",
    "bench:android-runtime-lanes-local": "bun run bench:android-release:repeat && bun run bench:android-hermes-iris-bridge && bun run bench:android-iris-qjs && bun run bench:android-runtime-lanes-report",
    "bench:android-runtime-lanes-report": "bun run tools/bench/write-android-runtime-lane-report.ts",
    "bench:extract-hermes": "bun run tools/bench/extract-hermes-report.ts",
    "bench:extract-hermes:android-release-fixture": "bun run tools/bench/extract-hermes-report.ts --input=tools/bench/fixtures/hermes-android-release.txt --output=artifacts/bench/hermes-android-release-baseline-fixture.json --require-release --require-new-architecture --require-case=iris-module-native-compute --require-case=turbomodule-number-round-trip --require-case=turbomodule-string-round-trip",
    "bench:extract-hermes:fixture": "bun run tools/bench/extract-hermes-report.ts --input=tools/bench/fixtures/hermes-metro.txt --output=artifacts/bench/hermes-baseline-fixture.json",
    "bench:extract-hermes:release": "bun run tools/bench/extract-hermes-report.ts --require-release --require-new-architecture --require-case=iris-module-native-compute --require-case=turbomodule-number-round-trip --require-case=turbomodule-string-round-trip",
    "bench:extract-hermes:release-fixture": "bun run tools/bench/extract-hermes-report.ts --input=tools/bench/fixtures/hermes-release.txt --output=artifacts/bench/hermes-release-baseline-fixture.json --require-release --require-new-architecture --require-case=iris-module-native-compute --require-case=turbomodule-number-round-trip --require-case=turbomodule-string-round-trip",
    "bench:js": "bun run tools/bench/run-js-baseline.ts",
    "bench:qjs": "mise exec -- cargo run --release -p iris-qjs --bin qjs-bench --",
    "bench:qjs:smoke": "mise exec -- cargo run --release -p iris-qjs --bin qjs-bench -- --smoke",
    "bench:smoke": "bun run tools/bench/run-js-baseline.ts --smoke",
    "bench:strict-hbc-engine-compare": "bun run tools/bench/run-strict-hbc-engine-comparison.ts --warmup=5 --iterations=15 --rounds=2",
    "bench:strict-hbc-engine-compare:repeat": "bun run tools/bench/run-strict-hbc-engine-comparison-repeat.ts --warmup=5 --iterations=15 --rounds=2",
    "bench:strict-hbc-engine-compare:smoke": "bun run tools/bench/run-strict-hbc-engine-comparison.ts --warmup=1 --iterations=3 --output=artifacts/bench/strict-hbc-engine-comparison-smoke.json",
    "bench:strict-hbc-call-targets": "bun run tools/bench/run-strict-hbc-engine-comparison.ts --case=js-compute --case=js-compute-lexical --case=math-call-diagnostic --case=math-call-bound-diagnostic --warmup=5 --iterations=15 --rounds=2 --output=artifacts/bench/strict-hbc-engine-comparison-call-targets.json",
    "bench:strict-hbc-compare-artifacts": "bun run tools/bench/compare-strict-hbc-engine-artifacts.ts",
    "bench:strict-hbc-compare-gate": "bun run tools/bench/compare-strict-hbc-engine-artifacts.ts --gate",
    "bench:strict-hbc-math-lookup": "bun run tools/bench/run-strict-hbc-engine-comparison.ts --case=math-lookup-diagnostic --case=math-lookup-bound-diagnostic --warmup=5 --iterations=15 --rounds=2 --output=artifacts/bench/strict-hbc-engine-comparison-math-lookup.json",
    "bench:strict-hbc-profile": "bun run tools/bench/run-strict-hbc-profile.ts",
    "bench:strict-hbc-source-shape": "bun run tools/bench/run-strict-hbc-engine-comparison.ts --case=numeric-loop --case=numeric-loop-lexical --case=js-compute --case=js-compute-lexical --case=property-loop --case=property-loop-lexical --case=typed-array-copy --case=typed-array-copy-lexical --warmup=5 --iterations=15 --rounds=2 --output=artifacts/bench/strict-hbc-engine-comparison-lexical-shape.json",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "vp:check": "vp check",
    "check": "bun run format:check && bun run lint && mise exec -- cargo check --workspace --all-targets && mise exec -- cargo test --workspace"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3",
    "vite-plus": "0.1.24"
  },
  "packageManager": "bun@1.3.14"
}
